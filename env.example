# ── CyberShield Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# Flask
SECRET_KEY=change-me-to-something-random-in-production
FLASK_DEBUG=false
PORT=5000

# Demo mode: set to "false" when you have a real Suricata install
DEMO_MODE=true
DEMO_EVENT_INTERVAL=1.5

# Suricata EVE JSON log path (default Suricata install)
SURICATA_EVE_LOG=/var/log/suricata/eve.json

# Threat engine tuning
MAX_ALERT_HISTORY=500
ANOMALY_WINDOW_SECONDS=60
BASELINE_PPS=120000

# GeoIP: download MaxMind GeoLite2-City.mmdb and set path here
# Requires: pip install geoip2
# Download: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
GEOIP_DB_PATH=

# CORS (restrict to your dashboard origin in production)
ALLOWED_ORIGINS=*
